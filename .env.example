# Copy to .env.local (git-ignored) and fill in real values.
# Register a Web app in the Xero developer portal to obtain the client
# credentials (see ARCHITECTURE.md §4 for scopes and the redirect URI).

# Xero OAuth 2.0 app credentials
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# Must exactly match the redirect URI registered in the Xero portal.
XERO_REDIRECT_URI=http://localhost:3000/api/xero/callback

# Secret used to sign/encrypt the session cookie (use a long random string).
SESSION_COOKIE_SECRET=
